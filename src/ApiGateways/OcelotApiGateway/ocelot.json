{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/me",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "user-api", "Port": 5077 }
      ],
      "UpstreamPathTemplate": "/api/auth/me",
      "UpstreamHttpMethod": [ "GET" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      }
    },
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "user-api", "Port": 5077 }
      ],
      "UpstreamPathTemplate": "/api/auth/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
    },
    {
      "DownstreamPathTemplate": "/api/adverts",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "advert-api", "Port": 5144 }
      ],
      "UpstreamPathTemplate": "/api/adverts",
      "UpstreamHttpMethod": [ "GET" ]
    },
    {
      "DownstreamPathTemplate": "/api/adverts/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "advert-api", "Port": 5144 }
      ],
      "UpstreamPathTemplate": "/api/adverts/{id}",
      "UpstreamHttpMethod": [ "GET" ]
    },
    {
      "DownstreamPathTemplate": "/api/adverts/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "advert-api", "Port": 5144 }
      ],
      "UpstreamPathTemplate": "/api/adverts/{everything}",
      "UpstreamHttpMethod": [ "POST", "GET" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      }
    },
    {
      "DownstreamPathTemplate": "/api/chat/dialogs/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "chat-api", "Port": 5251 }
      ],
      "UpstreamPathTemplate": "/api/chat/dialogs/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      }
    },
    {
      "DownstreamPathTemplate": "/chatHub/{everything}",
      "UpstreamPathTemplate": "/chatHub/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "chat-api",
          "Port": 5251
        }
      ],
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "IsWebSocket": true
    },
    {
      "DownstreamPathTemplate": "/api/files/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        { "Host": "file-api", "Port": 5170 }
      ],
      "UpstreamPathTemplate": "/api/files/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "DELETE", "PUT" ],
      "QoSOptions": {
        "TimeoutValue": 500000,
        "ExceptionsAllowedBeforeBreaking": 3,
        "DurationOfBreak": 1000,
        "BulkheadIsolation": {
          "MaxConcurrentRequests": 25, 
          "MaxQueueSize": 20          
        }
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://ocelot-api-gateway:5000"
  }
}
